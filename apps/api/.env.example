# Local dev Postgres via docker-compose.dev.yml (default for contributors)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_dev
# Cloud staging / production — uncomment & fill instead of the local URL above
# DATABASE_URL=postgresql://USER:PASSWORD@host/dbname?sslmode=require

# Required for `bun run test` (integration tests connect to a real Postgres
# over TCP). Local dev: `docker compose -f docker-compose.dev.yml up -d` then
# point this at `postgres://postgres:postgres@localhost:5432/app_dev`.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_test
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Google OAuth (Calendar + Meet)
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxx
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/google/callback
APP_BASE_URL=http://localhost:6173

# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Resend (transactional email). Without these the booking confirm flow
# completes without sending email instead of failing.
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@yourdomain.example

PORT=8787
