# ---- web (apps/web/.env, also read by docker-compose for build args) ----
VITE_API_URL=http://localhost:8787
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ---- api (apps/api/.env, also read by docker-compose) ----
# DATABASE_URL     : app role connection (RLS enforced at runtime — used by the API server)
# DATABASE_URL_ADMIN: admin role connection (BYPASSRLS — used by drizzle-kit migrations only)
# Local docker-compose: app/admin roles are created by the 0003_rls.sql migration.
#   app role   → postgres://app:app@localhost:5432/app_dev
#   admin role → postgres://admin:admin@localhost:5432/app_dev
DATABASE_URL=postgres://app:app@localhost:5432/app_dev
DATABASE_URL_ADMIN=postgres://admin:admin@localhost:5432/app_dev
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
PORT=8787

# ---- AI providers (任意) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
